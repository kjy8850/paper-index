# =====================================================================
# DS918+ (NAS) 전용 환경변수
# Synology Container Manager 의 Project 생성 시
# Environment 탭에 하나씩 붙여넣거나 이 파일을 .env 로 같이 업로드.
# =====================================================================

# ---- Postgres 기본 ----
PGDATABASE=papers
PGUSER=paperuser
# ⚠️ 반드시 긴 랜덤 문자열로 변경. 예) openssl rand -base64 24
PGPASSWORD=강력한_비밀번호_로_교체하세요

# ---- 바인딩 IP ----
# NAS 의 LAN IP (예: 192.168.1.50). 0.0.0.0 금지!
# 외부 접근 완전 차단이면 127.0.0.1 로 두고 미니PC 는 NAS 의 내부 프록시 사용.
# 일반적으론 NAS LAN IP 를 넣어 같은 공유기 내 미니PC 만 접속.
PG_BIND_IP=192.168.1.50
PGPORT=5432
