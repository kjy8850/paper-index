# ========================================
# 논문 색인 시스템 환경 변수
# 실제 사용 시 이 파일을 .env 로 복사하고 값을 채워넣으세요.
# ========================================

# ---- Gemini API ----
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=여기에_Gemini_API_키_입력
GEMINI_GEN_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=text-embedding-004

# ---- PostgreSQL (pgvector) ----
# docker-compose.yml 에서 기본값을 맞췄습니다.
PGHOST=localhost
PGPORT=5433
PGDATABASE=papers
PGUSER=paperuser
PGPASSWORD=paperpass
# Connection pool
PG_POOL_MAX=10

# ---- Ingest API 서버 ----
INGEST_PORT=8787
# n8n 에서 이 값을 Header(X-Api-Key)로 보내 인증.
# 개인용이지만 혹시 n8n 이 외부에 노출되면 위험하니 설정해두세요.
INGEST_API_KEY=바꾸세요_임의의_긴_문자열

# ---- 수집 파라미터 ----
# 하루 목표 수집량 (중복 제거 후)
DAILY_TARGET=300
# 동시 Gemini 호출 수 (Rate limit 안전 범위)
GEMINI_CONCURRENCY=3
# 요청 사이 최소 간격 (ms)
GEMINI_MIN_INTERVAL_MS=400
# 소스별 최대 수집량 (중복 전)
MAX_PER_SOURCE=200

# ---- 로그 ----
LOG_LEVEL=info

# ---- Semantic Scholar (선택) ----
# 미사용 시 익명 호출 가능하나 rate limit 낮음. API 키 있으면 권장.
# https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=
