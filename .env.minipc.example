# =====================================================================
# 미니PC (N150) 전용 환경변수 — v2 (5-Layer Pipeline)
# docker compose -f docker-compose.minipc.yml --env-file .env up -d
# (또는 이 파일을 .env 로 복사 후 그냥 up -d)
# =====================================================================

# ======================================================================
# Gemini (Layer 2 — Flash Batch 관련성 판단 + 임베딩)
# ======================================================================
GEMINI_API_KEY=여기에_Gemini_API_키_입력
GEMINI_GEN_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_CONCURRENCY=3
GEMINI_MIN_INTERVAL_MS=400
# Vertex Batch API (services/batch-runner) 가 사용
BATCH_MODEL=gemini-2.5-flash-lite
BATCH_MAX_PAPERS=200
BATCH_MIN_PAPERS=1
GCS_BUCKET=
GCP_PROJECT=
GCP_LOCATION=us-central1

# ======================================================================
# Anthropic Claude (Layer 4 — Deep Parser)
# https://console.anthropic.com/settings/keys
# ======================================================================
ANTHROPIC_API_KEY=여기에_Claude_API_키_입력
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_OUTPUT_TOKENS=4096
DEEP_PARSER_BATCH=4
DEEP_PARSER_POLL_MS=15000
DEEP_PARSER_MD_MAX=200000
# 일일 PDF 직접 투입 한도 (Claude PDF 직접 모드는 1건당 ~$0.09)
DAILY_PDF_LIMIT=10

# ======================================================================
# OpenAlex (Layer 1 — 신규 소스, polite pool 용 mailto)
# ======================================================================
OPENALEX_EMAIL=almexf88@gmail.com

# ======================================================================
# NAS Postgres 원격 접속
# ======================================================================
PGHOST=192.168.1.50
PGPORT=5432
PGDATABASE=papers
PGUSER=paperuser
PGPASSWORD=강력한_비밀번호_로_교체하세요
PG_POOL_MAX=10

# ======================================================================
# Ingest API (Express)
# ======================================================================
INGEST_PORT=8787
INGEST_API_KEY=임의의_긴_문자열_64자이상
STAGING_INSERT_CONCURRENCY=8

# ======================================================================
# Phase 1 / Phase 2 운영 파라미터
# ======================================================================
# Phase 1 — 과거 논문 대량 수집 (300건/일까지)
PHASE1_DAILY_TARGET=300
PHASE1_TIMEOUT_HOURS=20
PHASE1_MIN_BATCH=50
PHASE1_PER_KEYWORD=50
PHASE1_CALL_BUDGET_MS=90000
PHASE1_CALL_MAX_ITER=16

# Phase 2 — 일일 신규 논문만 수집
PHASE2_DAYS_WINDOW=14
MAX_PER_SOURCE=50
DAILY_TARGET=300

# ======================================================================
# n8n 스케줄러
# ======================================================================
N8N_PORT=5678
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=n8n_비밀번호_변경
TZ=Asia/Seoul

# ======================================================================
# Semantic Scholar (선택, 키 있으면 10 req/sec)
# ======================================================================
SEMANTIC_SCHOLAR_API_KEY=

# ======================================================================
# Layer 5 — publisher (papers_parsed → research_papers + embedding)
# ======================================================================
PUBLISHER_POLL_MS=20000

# ======================================================================
# Layer 3 — pdf-worker / docling-svc
# ======================================================================
DOCLING_URL=http://localhost:8089
PDF_WORKER_BATCH=5
PDF_WORKER_POLL_MS=10000
PDF_MAX_BYTES=52428800
PDF_FETCH_TIMEOUT_MS=60000
DOCLING_TIMEOUT_MS=240000
PDF_MIN_MD_BYTES=2048
PDF_MAX_ATTEMPTS=3

# ======================================================================
# MCP HTTP (선택: Claude Web Custom Connector 용)
# docker compose --profile mcp-http -f docker-compose.minipc.yml up -d
# ======================================================================
MCP_HTTP_PORT=8788
MCP_HTTP_TOKEN=Claude_Web_전용_공유_시크릿_긴_랜덤_문자열

# ======================================================================
# 로그
# ======================================================================
LOG_LEVEL=info
