# =====================================================================
# 미니PC (N150) 전용 환경변수
# docker compose -f docker-compose.minipc.yml --env-file .env up -d
# (또는 이 파일을 .env 로 복사 후 그냥 up -d)
# =====================================================================

# ---- Gemini API ----
# https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_Gemini_API_키_입력
GEMINI_GEN_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=text-embedding-004
GEMINI_CONCURRENCY=3
GEMINI_MIN_INTERVAL_MS=400

# ---- NAS Postgres 원격 접속 ----
# NAS 의 LAN IP 와 .env.nas 에서 설정한 비밀번호 그대로.
PGHOST=192.168.1.50
PGPORT=5432
PGDATABASE=papers
PGUSER=paperuser
PGPASSWORD=강력한_비밀번호_로_교체하세요
PG_POOL_MAX=10

# ---- Ingest API ----
INGEST_PORT=8787
# 임의의 긴 랜덤 문자열. n8n → ingest 호출 시 X-Api-Key 로 검증.
INGEST_API_KEY=임의의_긴_문자열_64자이상

# ---- 수집 파라미터 ----
DAILY_TARGET=300
MAX_PER_SOURCE=50

# ---- n8n ----
N8N_PORT=5678
N8N_HOST=localhost           # 외부에서 접속하려면 미니PC IP 로.
N8N_USER=admin
N8N_PASSWORD=n8n_비밀번호_변경
TZ=Asia/Seoul

# ---- Semantic Scholar (선택) ----
SEMANTIC_SCHOLAR_API_KEY=

# ---- MCP HTTP (선택: Claude Web Custom Connector 용) ----
# docker compose --profile mcp-http -f docker-compose.minipc.yml up -d
MCP_HTTP_PORT=8788
MCP_HTTP_TOKEN=Claude_Web_전용_공유_시크릿_긴_랜덤_문자열

# ---- 로그 ----
LOG_LEVEL=info
